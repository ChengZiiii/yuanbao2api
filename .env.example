# 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# === 必需 ===

# 从浏览器复制的完整 Cookie
# 打开 https://yuanbao.tencent.com，登录后按 F12 打开控制台
# 在"网络"标签中找到任意 /api/chat/ 请求，复制请求头中的 Cookie
YUANBAO_COOKIE="hy_token=xxx; hy_user=xxx; ..."


# === 可选 ===

# Agent ID（默认: naQivTmsDa）
YUANBAO_AGENT_ID="naQivTmsDa"

# 服务端口（默认: 3000）
PORT=3000

# Gin 运行模式（debug 或 release，默认: debug）
# GIN_MODE=release

# API Key — 第三方软件需要认证时使用
# 设置后，请求 /v1/* 端点需添加 Authorization: Bearer <值>
# 例如：curl -H "Authorization: Bearer mykey" ...
# 不设置则无需认证，完全向后兼容
API_KEY=sk-your-key-here

# 最大同时请求数（默认: 1）— 超过此数的请求自动排队
MAX_CONCURRENCY=1

# 队列超时（秒，默认: 120）— 排队超过此时间返回 429
QUEUE_TIMEOUT_SECONDS=120

# 请求完成后的冷却时间（毫秒，默认: 0）
# 单账号建议设为 500~1000 降低风控概率
REQUEST_COOLDOWN_MS=800
